{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadCloudTrailObjectsFromS3",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject"
      ],
      "Resource": "arn:aws:s3:::<cloudtrail-bucket-name>/*"
    },
    {
      "Sid": "ConsumeS3EventNotificationsFromSQS",
      "Effect": "Allow",
      "Action": [
        "sqs:ReceiveMessage",
        "sqs:DeleteMessage",
        "sqs:ChangeMessageVisibility"
      ],
      "Resource": "arn:aws:sqs:<region>:<account-id>:<queue-name>"
    }
  ]
}
