{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowCortexToAssumeRole",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::<cortex-aws-account-id>:root"
      },
      "Action": "sts:AssumeRole",
      "Condition": {
        "StringEquals": {
          "sts:ExternalId": "<external-id-from-cortex>"
        }
      }
    }
  ]
}
