{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowCortexToAssumeRole",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::006742885340:root"
      },
      "Action": "sts:AssumeRole",
      "Condition": {
        "StringEquals": {
          "sts:ExternalId": "<customer-generated-uuidv4-external-id>"
        }
      }
    }
  ]
}
